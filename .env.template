# ─────────────────────────────────────────────────
# Google Maps
# ─────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# ─────────────────────────────────────────────────
# Supabase — App URL base (OAuth redirects + invitation links) 
# ─────────────────────────────────────────────────
# Dev: http://localhost:3000
# Prod: https://<dominio-final>
NEXT_PUBLIC_APP_URL=

# ─────────────────────────────────────────────────
# Supabase — Auth (cliente, expuesto al browser) 
# Dashboard → Settings → API → "Publishable and secret API keys" tab
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────
# Supabase — Admin (server-only, NEVER expose) 
# Dashboard → Settings → API → Secret keys → "default" 
# ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────
# Database — Supabase Postgres 
# Pooler (para la app — serverless compatible) 
# ─────────────────────────────────────────────────
DATABASE_URL=
# Directa (para migraciones)
DIRECT_URL=

# ─────────────────────────────────────────────────
# Google OAuth (compartido: Better Auth + Supabase Auth durante transición)
# ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────
# Boneyard (solo para desarrollo — cookie de session para generar skeletons) 
# ─────────────────────────────────────────────────
BONEYARD_SESSION_TOKEN=